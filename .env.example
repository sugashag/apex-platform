# ---------------------------------------------------------------------------
# APEX Platform — environment variables
# Copy this file to `.env` and fill in real values for local development.
# In production, these are sourced from your secrets manager.
# ---------------------------------------------------------------------------

# --- Application -----------------------------------------------------------
# Logical environment name. One of: development | staging | production
ENVIRONMENT=development

# Application version (surfaced via /health). Bump on each release.
VERSION=0.1.0

# --- Database --------------------------------------------------------------
# Async SQLAlchemy URL. Must use the asyncpg driver.
# Local docker-compose default: postgresql+asyncpg://apex:apex@postgres:5432/apex
DATABASE_URL=postgresql+asyncpg://apex:apex@localhost:5432/apex

# Sync URL used by Alembic. Same DB, sync driver.
DATABASE_URL_SYNC=postgresql+psycopg://apex:apex@localhost:5432/apex

# --- Redis -----------------------------------------------------------------
# Used for caching, rate limiting, and (later) background job queues.
REDIS_URL=redis://localhost:6379/0

# --- Auth / JWT ------------------------------------------------------------
# Secret used to sign JWT access tokens. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
# NEVER commit a real value. Rotate on suspected compromise.
SECRET_KEY=change-me-to-a-long-random-string

# JWT signing algorithm. HS256 (HMAC SHA-256) is the standard choice.
ALGORITHM=HS256

# Access token lifetime in minutes.
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- NetSuite (Phase 1+) ---------------------------------------------------
# Per-workspace NetSuite credentials live in the `workspaces` table.
# These platform-level fallbacks are optional and used only for dev/testing.
# NETSUITE_DEFAULT_ACCOUNT_ID=
# NETSUITE_DEFAULT_CONSUMER_KEY=
# NETSUITE_DEFAULT_CONSUMER_SECRET=

# --- Twilio (Phase 2 — Communications) -------------------------------------
# Voice + SMS provider. Leave unset in CI/dev — services degrade gracefully.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+1xxxxxxxxxx
# Required for the WebRTC softphone — the TwiML App's voice URL handles dial-out.
TWILIO_TWIML_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# API Key + Secret are used to mint short-lived Twilio Client capability tokens
# without sharing the master auth token with the browser.
TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SECRET=your_api_key_secret

# --- Resend (Phase 2 — Communications) -------------------------------------
# Transactional email provider used for outbound thread replies.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=outbound@yourdomain.com

# --- SLA defaults (Phase 2 — Communications) -------------------------------
# Time windows applied to new inbound threads, in minutes.
SLA_FIRST_RESPONSE_MINUTES=60
SLA_RESOLUTION_MINUTES=480

# --- Anthropic (Phase 3 — AI Layer) ----------------------------------------
# Claude API key. Leave unset to run agents in mock mode (CI/dev).
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- ARQ Worker (Phase 3 — AI Layer) ---------------------------------------
# Background job runner — concurrency + per-job timeout (seconds).
WORKER_MAX_JOBS=10
WORKER_JOB_TIMEOUT=120

# --- PostHog (Phase 4 — Attribution) ---------------------------------------
# Shared secret used to authenticate server-side webhook deliveries from
# PostHog. Sent as the `X-PostHog-Signature` header.
POSTHOG_WEBHOOK_SECRET=your_posthog_webhook_secret

# --- Attribution / Website Integration (Phase 4) ---------------------------
# Public base URL of the APEX API — embedded into the marketing-site JS
# snippet so visitor events can be POSTed back.
API_BASE_URL=https://your-apex-instance.railway.app

# Per-IP rate limit for the public /track/* endpoints (requests per minute).
TRACKING_RATE_LIMIT_PER_MINUTE=100
