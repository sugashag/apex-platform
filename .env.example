# ---------------------------------------------------------------------------
# APEX Platform — environment variables
# Copy this file to `.env` and fill in real values for local development.
# In production, these are sourced from your secrets manager.
# ---------------------------------------------------------------------------

# --- Application -----------------------------------------------------------
# Logical environment name. One of: development | staging | production
ENVIRONMENT=development

# Application version (surfaced via /health). Bump on each release.
VERSION=0.1.0

# --- Database --------------------------------------------------------------
# Async SQLAlchemy URL. Must use the asyncpg driver.
# Local docker-compose default: postgresql+asyncpg://apex:apex@postgres:5432/apex
DATABASE_URL=postgresql+asyncpg://apex:apex@localhost:5432/apex

# Sync URL used by Alembic. Same DB, sync driver.
DATABASE_URL_SYNC=postgresql+psycopg://apex:apex@localhost:5432/apex

# --- Redis -----------------------------------------------------------------
# Used for caching, rate limiting, and (later) background job queues.
REDIS_URL=redis://localhost:6379/0

# --- Auth / JWT ------------------------------------------------------------
# Secret used to sign JWT access tokens. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
# NEVER commit a real value. Rotate on suspected compromise.
SECRET_KEY=change-me-to-a-long-random-string

# JWT signing algorithm. HS256 (HMAC SHA-256) is the standard choice.
ALGORITHM=HS256

# Access token lifetime in minutes.
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- NetSuite (Phase 1+) ---------------------------------------------------
# Per-workspace NetSuite credentials live in the `workspaces` table.
# These platform-level fallbacks are optional and used only for dev/testing.
# NETSUITE_DEFAULT_ACCOUNT_ID=
# NETSUITE_DEFAULT_CONSUMER_KEY=
# NETSUITE_DEFAULT_CONSUMER_SECRET=
